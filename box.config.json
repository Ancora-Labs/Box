{
  "loopIntervalMs": 20000,
  "maxParallelWorkers": 10,
  "defaultBranchPrefix": "box/task-",
  "workerImage": "box-worker:local",
  "workspaceDir": ".box-work",
  "progressFile": "state/progress.txt",
  "policyFile": "policy.json",
  "git": {
    "autoCreatePr": true,
    "autoMergeOnGreen": false,
    "autoMergeWaitSeconds": 300,
    "autoMergePollSeconds": 15,
    "autoMergeMethod": "squash",
    "requiredCheckRuns": [],
    "requiredStatusContexts": []
  },
  "runtime": {
    "reviewerProvider": "copilot",
    "stopOnError": true,
    "autonomousMaxAttemptsPerTask": 3,
    "autonomousTaskSplitOnFailure": true,
    "maxQueuedTasks": 30,
    "runningTaskTimeoutMinutes": 0,
    "workerTimeoutMinutes": 90,
    "blockedTaskRequeueMinutes": 120,
    "semanticFailureWindowMinutes": 180,
    "semanticFailureMaxCount": 3,
    "securityFamilyFailureMaxCount": 3,
    "securityFamilyFailureWindowMinutes": 240,
    "securityFamilyCooldownMinutes": 240,
    "environmentBlockerCooldownMinutes": 180,
    "strategicLoopMinutes": 10,
    "leadershipBootstrapCooldownMinutes": 5,
    "sprintFreezeRatio": 0.8,
    "requireTaskContract": true,
    "autonomySupervisorEnabled": true,
    "deepProjectAnalysisEnabled": true,
    "issueHandoffEnabled": true,
    "issueAutoCloseOnRecovery": true,
    "workerMaxFilesChanged": 0,
    "workerForbiddenPathPrefixes": [
      ".next/",
      "node_modules/"
    ],
    "disableWaveParallelDispatch": false,
    "dashboardEnabled": false,
    "prometheusAnalysisFreshnessMinutes": 60,
    "jesusTimeoutMs": 1800000,
    "jesusDirectiveFreshnessMinutes": 30,
    "plannerMaxGenerations": 3,
    "maxTacticalCycles": 6,
    "maxDescendantDepth": 3,
    "maxSplitCountPerLineage": 10,
    "semanticSimilarityThreshold": 0.92,
    "retryStrategy": "adaptive",
    "adaptiveRetry": {
      "environment": {
        "cooldownMinutes": 30,
        "maxRetries": 3,
        "escalateAfter": 3,
        "escalationTarget": "daemon_queue"
      },
      "logic_defect": {
        "maxReworkAttempts": 2,
        "escalateAfter": 2,
        "reworkQueue": "rework_queue",
        "verificationStep": "verification_gate",
        "escalationTarget": "daemon_queue"
      },
      "policy": {
        "reassignBeforeAttempt": 2,
        "splitAfterAttempt": 2,
        "escalateAfter": 3,
        "escalationTarget": "daemon_queue"
      },
      "verification": {
        "maxReworkAttempts": 2,
        "escalateAfter": 2,
        "reworkQueue": "rework_queue",
        "verificationStep": "verification_gate",
        "escalationTarget": "daemon_queue"
      },
      "model": {
        "cooldownMinutes": 15,
        "maxRetries": 3,
        "escalateAfter": 3,
        "escalationTarget": "daemon_queue"
      },
      "external_api": {
        "cooldownMinutes": 10,
        "maxRetries": 3,
        "escalateAfter": 3,
        "escalationTarget": "daemon_queue"
      }
    },
    "contextRevisionRequiredForSameFailureRetry": true,
    "staleIssueMaxAgeHours": 24,
    "staleIssueCloseGraceHours": 2,
    "runtimeBudget": {
      "maxTasksPerCycle": 20,
      "maxWorkerSpawnsPerCycle": 20,
      "maxSplitsPerCycle": 8
    },
    "interBatchDelayMs": 90000,
    "maxCapacityMode": false,
    "maxPlansPerDependencyBatch": 4,
    "verificationCommandTimeoutMs": 3600000,
    "workerContextTokenLimit": 150000,
    "trustBoundaryMode": "warn",
    "planQualityMinScore": 0,
    "mandatoryTaskCoverageMode": "enforce",
    "enforceSpecialistUtilizationAdmission": true,
    "interventionJudgeEnabled": true,
    "interventionJudgeMinSamples": 3,
    "interventionJudgeWindowSize": 5,
    "interventionJudgeAutoApplyLowRisk": false,
    "interventionJudgeAiEnabled": true,
    "interventionJudgeAiTimeoutMs": 120000,
    "interventionJudgeExecuteRollback": false,
    "autonomyBand": {
      "enabled": true,
      "shadowMode": true,
      "thresholds": {
        "minBootstrapCycles": 10,
        "stabilizingWindow": 30,
        "hardGuardrailWindow": 50,
        "compositeScoreMin": 0.72,
        "completionRateMin": 0.75,
        "premiumEfficiencyMin": 0.60,
        "athenaRejectRateMax": 0.15,
        "hardGuardrailBreachMax": 2,
        "inBandMinBenchmarkGain": 0.10,
        "inBandMaxCompletionVariance": 0.05,
        "inBandRequireCompletedPhase": true,
        "regressCrashWindow": 10,
        "regressCrashThreshold": 3,
        "regressCompletionWindow": 10,
        "regressCompletionMin": 0.40,
        "regressAthenaRejectWindow": 5,
        "regressAthenaRejectMax": 0.40,
        "exploitationWindow": 10,
        "exploitationMinBenchmarkGain": 0.15,
        "exploitationMaxCompletionVariance": 0.04
      }
    }
  },
  "roadmap": {
    "strategy": "roadmap-first",
    "maxParallelDomainWorkers": 5
  },
  "escalationPolicy": {
    "userAlertRetryThreshold": 3
  },
  "roleRegistry": {
    "ceoSupervisor": {
      "id": "ceo-supervisor",
      "name": "Jesus",
      "model": "Claude Sonnet 4.6",
      "provider": "copilot"
    },
    "deepPlanner": {
      "id": "deep-planner",
      "name": "Prometheus",
      "model": "gpt-5.3-codex",
      "provider": "copilot"
    },
    "qualityReviewer": {
      "id": "quality-reviewer",
      "name": "Athena",
      "model": "Claude Sonnet 4.6",
      "provider": "copilot"
    },
    "workers": {
      "evolution": {
        "id": "worker-evolution",
        "name": "Evolution Worker",
        "model": "gpt-5.3-codex"
      },
      "quality": {
        "id": "worker-quality",
        "name": "quality-worker",
        "model": "gpt-5.3-codex",
        "lane": "quality"
      },
      "governance": {
        "id": "worker-governance",
        "name": "governance-worker",
        "model": "gpt-5.3-codex",
        "lane": "governance"
      },
      "infrastructure": {
        "id": "worker-infrastructure",
        "name": "infrastructure-worker",
        "model": "gpt-5.3-codex",
        "lane": "infrastructure"
      },
      "integration": {
        "id": "worker-integration",
        "name": "integration-worker",
        "model": "gpt-5.3-codex",
        "lane": "integration"
      },
      "observation": {
        "id": "worker-observation",
        "name": "observation-worker",
        "model": "gpt-5.3-codex",
        "lane": "observation"
      }
    }
  },
  "planner": {
    "useReviewerForPlanning": true,
    "maxTasks": 0,
    "enforcePrometheusExecutionStrategy": true,
    "defaultMaxWorkersPerWave": 10,
    "specialistFillThreshold": 1,
    "preferFewestWorkers": true,
    "allowSameCycleFollowUps": false,
    "requireDependencyAwareWaves": false,
    "splitConflictingPlansAcrossBatches": false,
    "nucleusFrontierMode": true,
    "compactSingletonWaves": true
  },
  "selfImprovement": {
    "enabled": true,
    "forceEveryComplete": false,
    "maxReports": 200,
    "maxImprovementTasksPerCycle": 3,
    "enforceCoreModuleGuard": true,
    "coreProtectedModules": [
      "src/core/orchestrator.ts",
      "src/core/policy_engine.ts",
      "src/core/catastrophe_detector.ts",
      "src/core/guardrail_executor.ts"
    ],
    "knowledgeMemoryEnabled": true,
    "experimentEngineEnabled": true,
    "shadowPolicy": {
      "enabled": true,
      "threshold": 0.1,
      "cycleWindow": 20,
      "minSampleSize": 3
    }
  },
  "athena": {
    "forceAiPostmortem": false
  },
  "canary": {
    "enabled": true,
    "defaultRatio": 0.2,
    "minCyclesToObserve": 2,
    "promotion": {
      "minTaskSuccessRate": 0.8,
      "maxErrorRate": 0.1
    },
    "rollback": {
      "triggerErrorRate": 0.25,
      "triggerTaskSuccessRateLow": 0.5
    },
    "auditLogPath": "state/canary_audit.jsonl",
    "ledgerPath": "state/canary_ledger.json",
    "governance": {
      "canaryRatio": 0.2,
      "cohortSelectionAlgorithm": "hash-mod",
      "measurementWindowCycles": 5,
      "falseBlockRateMax": 0.02,
      "safetyScoreMin": 0.95,
      "falseBlockRateTrigger": 0.05,
      "safetyScoreTriggerLow": 0.8,
      "breachAction": "halt_new_assignments",
      "auditLogPath": "state/governance_canary_audit.jsonl",
      "ledgerPath": "state/governance_canary_ledger.json"
    }
  },
  "systemGuardian": {
    "enabled": true,
    "cooldownMinutes": 30,
    "trashTaskRatioThreshold": 0.35,
    "repeatedFailureThreshold": 4,
    "orphanedCheckpointThreshold": 4,
    "staleWorkerMinutes": 20
  },
  "gates": {
    "requireBuild": true,
    "requireTests": true,
    "requireLint": false,
    "requireSecurityScan": true,
    "minCoveragePercent": 80
  },
  "copilot": {
    "strategy": "task-best",
    "defaultModel": "gpt-5.3-codex",
    "preferredModelsByTaskKind": {
      "scan": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "analysis": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "planning": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "implementation": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "test": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "qa": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "security": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "devops": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "refactor": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "quality": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "stability": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "production": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ]
    },
    "preferredModelsByRole": {
      "Jesus": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "Prometheus": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "Athena": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ],
      "Evolution Worker": [
        "gpt-5.3-codex",
        "Claude Sonnet 4.6"
      ]
    },
    "opusModel": "gpt-5.3-codex",
    "allowOpusEscalation": false,
    "opusEscalationKeywords": [
      "critical",
      "security",
      "architecture",
      "incident",
      "severe"
    ],
    "neverUseModels": [
      "Claude Opus 4.6 (fast mode) (preview)",
      "Claude Opus 4.6 Fast",
      "claude-opus-4.6-fast",
      "Claude Opus 4.5 Fast",
      "claude-opus-4.5-fast"
    ],
    "bannedModelPatterns": [
      "fast",
      "preview",
      "30x"
    ],
    "modelPolicy": {
      "opusAllowedForLargeTasks": true,
      "opusMinEstimatedLines": 3000,
      "opusMinDurationMinutes": 120,
      "opusAllowedComplexities": [
        "critical",
        "massive",
        "high"
      ],
      "3xRateAllowed": true,
      "3xRateMinDurationMinutes": 60,
      "30xRateAllowed": false,
      "fastModeAllowed": false
    },
    "allowedModels": [
      "Claude Sonnet 4.6",
      "GPT-5.2-Codex",
      "gpt-5.3-codex"
    ],
    "maxMultiplier": 1,
    "opusMinBudgetUsd": 2,
    "opusMonthlyMaxCalls": 8,
    "multipliers": {
      "Claude Haiku 4.5": 0.33,
      "Claude Sonnet 4.5": 1,
      "Claude Sonnet 4.6": 1,
      "Claude Opus 4.6": 3,
      "GPT-5 mini": 0,
      "GPT-4.1": 0,
      "GPT-5.2-Codex": 1,
      "gpt-5.3-codex": 1,
      "Grok Code Fast 1": 0,
      "Raptor mini": 0
    },
    "taskKindRouting": {
      "default": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/box-plan-and-implement.prompt.md"
      },
      "quality": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/fix-failing-tests.prompt.md"
      },
      "production": {
        "agent": "box-team-lead",
        "promptFile": ".github/prompts/box-plan-and-implement.prompt.md"
      },
      "stability": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/backend-stability.prompt.md"
      },
      "refactor": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/backend-stability.prompt.md"
      },
      "scan": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/scan-fix.prompt.md"
      },
      "devops": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/devops-triage.prompt.md"
      },
      "security": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/security-fix.prompt.md"
      },
      "frontend": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/frontend-fix.prompt.md"
      },
      "backend": {
        "agent": "box-coder",
        "promptFile": ".github/prompts/backend-stability.prompt.md"
      }
    }
  },
  "slo": {
    "enabled": true,
    "thresholds": {
      "decisionLatencyMs": 900000,
      "dispatchLatencyMs": 30000,
      "verificationCompletionMs": 3600000
    },
    "breachSeverity": {
      "decisionLatencyMs": "high",
      "rollbackEngine": {
        "enabled": true,
        "oneCycleSlaMs": 5000,
        "incidentLogPath": "state/rollback_incidents.jsonl",
        "lockFilePath": "state/rollback_lock.json",
        "baselineRefPath": "state/project_baseline.json",
        "configFilePath": "box.config.json",
        "policyFilePath": "policy.json"
      },
      "dispatchLatencyMs": "high",
      "verificationCompletionMs": "critical"
    },
    "degradedOnBreach": true
  },
  "governanceFreeze": {
    "enabled": false,
    "monthTrigger": 12,
    "manualOverrideActive": false,
    "highRiskThreshold": 0.7,
    "rollbackThroughputCollapseThreshold": 0.5,
    "weeklyMetricsPath": "state/freeze_weekly_metrics.json",
    "yearEndReportPath": "state/year_end_report.json",
    "nextYearSeedPath": "state/next_year_seed.json"
  },
  "selfDev": {
    "enabled": true,
    "recoveryTag": "box/recovery-v0.1.0-pre-selfdev",
    "maxFilesPerPr": 8,
    "mandatoryGates": [
      "lint",
      "test"
    ],
    "forbiddenBranchTargets": [
      "main",
      "master"
    ],
    "branchPrefix": "box/selfdev-",
    "criticalFiles": [
      "src/core/orchestrator.ts",
      "src/core/self_dev_guard.ts",
      "src/core/daemon_control.ts",
      "src/core/policy_engine.ts",
      "src/cli.ts",
      ".env",
      "policy.json"
    ],
    "cautionFiles": [
      "src/core/self_improvement.ts",
      "src/core/athena_reviewer.ts",
      "src/core/jesus_supervisor.ts",
      "src/core/prometheus.ts",
      "box.config.json",
      "package.json"
    ]
  },
  "athenaCalibration": {
    "maxDeviationScore": 0.25,
    "fixturesDir": "tests/fixtures/calibration",
    "stateFile": "state/athena_calibration_run.json"
  },
  "catastropheDetector": {
    "staleCriticalStateAgeMs": 28800000,
    "sloCascadingBreachConsecutive": 5
  },
  "workerPool": {
    "minLanes": 2,
    "specializationTargets": {
      "minSpecializedShare": 0.35,
      "fitScoreThreshold": 0.65
    }
  }
}
