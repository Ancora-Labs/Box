{
  "name": "box-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": ".electron-build/electron/main.js",
  "description": "Repo-agnostic autonomous engineering orchestrator starter",
  "scripts": {
    "build": "npm run typecheck",
    "lint": "eslint src/",
    "test": "node --import tsx scripts/run_tests.ts",
    "typecheck": "tsc -p tsconfig.typecheck.json --noEmit",
    "box:on": "node --import tsx src/cli.ts on",
    "box:off": "node --import tsx src/cli.ts off",
    "box:up": "pwsh -NoProfile -File scripts/box-up.ps1",
    "box:down": "pwsh -NoProfile -File scripts/box-down.ps1",
    "box:start": "node --import tsx src/cli.ts start",
    "box:stop": "node --import tsx src/cli.ts stop",
    "box:rebase": "node --import tsx src/cli.ts rebase",
    "box:park": "node --import tsx scripts/box_park.ts",
    "box:once": "node --import tsx src/cli.ts once",
    "box:dashboard": "node --import tsx src/dashboard/live_dashboard.ts",
    "atlas:start": "node --import tsx src/atlas/server.ts",
    "atlas:ctl": "node --import tsx src/atlas/lifecycle.ts",
    "atlas:desktop:build": "tsc -p tsconfig.electron.json",
    "atlas:desktop": "npm run atlas:desktop:build && electron .electron-build\\electron\\main.js",
    "atlas:desktop:package": "node --import tsx scripts/atlas_desktop_package.ts",
    "atlas:open": "npm run atlas:desktop",
    "prometheus:watch": "node --import tsx scripts/watch_prometheus_live.ts",
    "worker:run": "node --import tsx src/workers/run_task.ts",
    "doctor": "node --import tsx src/cli.ts doctor"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "build": {
    "appId": "com.ancoralabs.atlas",
    "productName": "ATLAS",
    "files": [
      "package.json",
      ".electron-build/**/*",
      "electron/renderer/**/*"
    ],
    "extraFiles": [
      "box.config.json"
    ],
    "win": {
      "target": [
        "dir"
      ],
      "executableName": "ATLAS",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "tsx": "^4.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2"
  }
}
